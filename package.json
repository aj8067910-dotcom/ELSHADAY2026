{
  "name": "grupo-elshaday",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma de discipulado, comunhão e engajamento gamificado — Grupo Elshaday",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:seed": "npm run prisma:seed -w apps/api"
  },
  "engines": {
    "node": ">=20"
  }
}
